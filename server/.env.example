# ── EcoKids India — Complete Environment Configuration ──
# Copy this to .env and fill in actual values for your deployment.
# DO NOT commit .env to git — use .env.example only!

# ── Server Core ──
NODE_ENV=development
PORT=5001
APP_NAME=EcoKids India
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://app.ecokids.in

# ── Appwrite (Student Email OTP) ──
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69b6ea3b0010c4b2e448

# ── Database (MongoDB) ──
MONGO_URI=mongodb://localhost:27017/ecokids
MONGO_URI_PROD=mongodb+srv://user:password@cluster.mongodb.net/ecokids?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10

# ── Redis Cache & Queues ──
REDIS_URL=redis://localhost:6379
REDIS_MAXMEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru

# ── JWT Authentication ──
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-64-chars
JWT_EXPIRE=15m
REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-64-chars
REFRESH_TOKEN_EXPIRE=30d

# ── Security & CORS ──
ALLOWED_PROXY_HOSTS=ecokids.net,www.ecokids.net,ncert.nic.in,cbse.gov.in,api.openweathermap.org

# ── File Upload (Cloudinary) ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── AWS S3 (PDFs, Backups) ──
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
PDF_STORAGE_BUCKET=ecokids-pdfs
UPLOAD_STORAGE_BUCKET=ecokids-uploads
BACKUP_STORAGE_BUCKET=ecokids-backups
BACKUP_RETENTION_DAYS=30
STORAGE_REGION=ap-south-1
DATA_RESIDENCY_REGION=ap-south-1
ENFORCE_INDIA_DATA_RESIDENCY=true

# ── AI Services (Anthropic Claude + Google Vision) ──
ANTHROPIC_API_KEY=sk-ant-your-anthropic-apikey-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
NVIDIA_API_KEY=CHANGE_ME
# Google Cloud Vision API — used by aiVerificationWorker for image label detection
# Get key: console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable: Cloud Vision API must be enabled for the project
GOOGLE_VISION_API_KEY=your-google-vision-api-key-here

# ── Feature Flags (A/B Testing) ──
# Set to 'true' to enable each feature
FF_AI_CHATBOT=false
FF_AI_LEARNING_PATH=false
FF_AI_PHOTO_VERIFY=false
FF_AI_QUIZ_GENERATOR=false
FF_ECO_STORE=false
FF_BUDDY_SYSTEM=false
FF_ECO_FEED=true
FF_SEASONAL_EVENTS=true
FF_WEEKLY_MISSIONS=true
FF_ACHIEVEMENT_TREE=false
FF_SCHOOL_CHALLENGES=false
FF_CLASSROOM_ANALYTICS=false
FF_LESSON_PLAN_BUILDER=false
FF_PARENT_REPORT_CARDS=false
FF_ECO_CLUB_HUB=false

# ── Firebase Cloud Messaging (FCM Push Notifications) ──
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-firebase-key-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ── Monitoring & Observability ──
METRICS_ENABLED=true
PROMETHEUS_SCRAPE_INTERVAL=15
GRAFANA_ADMIN_PASSWORD=admin
CERT_IN_CONTACT_EMAIL=security@ecokids.in
UDISE_API_URL=https://api.udiseplus.gov.in/v1
UDISE_API_KEY=your-udise-api-key
BACKUP_ENCRYPTION_KEY=replace_with_32_char_secret

# ── Notifications (Slack) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Error Tracking (Sentry) ──
SENTRY_DSN=https://key@sentry.io/projectid

# ── Logging ──
LOG_LEVEL=info
PINO_LOG_LEVEL=info

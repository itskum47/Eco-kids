{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyNonIndiaRegionReplication",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:PutBucketReplication",
        "s3:ReplicateObject",
        "s3:ReplicateDelete",
        "s3:ReplicateTags"
      ],
      "Resource": [
        "arn:aws:s3:::ecokids-*",
        "arn:aws:s3:::ecokids-*/*"
      ],
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": "ap-south-1"
        }
      }
    },
    {
      "Sid": "AllowEncryptedWritesOnly",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::ecokids-*/*",
      "Condition": {
        "StringNotEquals": {
          "s3:x-amz-server-side-encryption": "AES256"
        }
      }
    }
  ]
}

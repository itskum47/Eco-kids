{
  "name": "ecokids-server",
  "version": "1.0.0",
  "description": "Backend API for EcoKids India platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "worker:cleanup": "node workers/startCleanupWorker.js",
    "worker:gamification": "node workers/gamificationWorker.js",
    "worker:outbox": "node workers/startOutboxWorker.js",
    "dev": "nodemon server.js",
    "seed": "node seed/seedData.js",
    "seed:demo": "node scripts/seed-demo-users.js",
    "seed:quizzes": "node scripts/seed-quizzes.js",
    "seed:trees": "node scripts/seedTreeSpecies.js",
    "seed:all": "node scripts/seed-demo-users.js && node scripts/seed-quizzes.js && node scripts/seed-conference-demo.js",
    "test": "jest",
    "backup": "node scripts/backup.js",
    "backup:schedule": "node scripts/scheduler.js",
    "restore": "node scripts/restore.js",
    "restore:list": "node scripts/restore.js --list",
    "restore:latest": "node scripts/restore.js --latest",
    "monitor": "node scripts/monitoringScheduler.js",
    "phase3:setup": "node ../scripts/setup-phase3.js",
    "phase3:add-attrs": "node ../scripts/add-attributes.js",
    "phase3:seed": "node ../scripts/seed-test-data.js"
  },

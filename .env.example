# PART 1 - W6: EcoKids Complete Environment Variables
# Copy this to .env and fill in actual values for your deployment
# Production deployment checklist: Mark all REQUIRED variables

# ==========================================
# APPLICATION ENVIRONMENT
# ==========================================
NODE_ENV=production                               # development, staging, production (REQUIRED)
PORT=5001                                         # Server port (REQUIRED)
VITE_API_URL=http://localhost:5001               # Frontend API endpoint for Vite (REQUIRED)
VITE_SOCKET_URL=http://localhost:5001            # Socket.io endpoint (REQUIRED)

# ==========================================
# APPWRITE (EMAIL OTP)
# ==========================================
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1         # Appwrite API endpoint
APPWRITE_PROJECT_ID=69b6ea3b0010c4b2e448                   # Appwrite project ID
VITE_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1    # Frontend Appwrite endpoint
VITE_APPWRITE_PROJECT_ID=69b6ea3b0010c4b2e448              # Frontend Appwrite project ID

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB Atlas Connection (Production)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ecokids?retryWrites=true&w=majority  # (REQUIRED)

# OR Local MongoDB (Development)
# MONGO_HOST=localhost
# MONGO_PORT=27017
# MONGO_DB=ecokids
# MONGO_USER=ecokids
# MONGO_PASSWORD=your_password

# Database Connection Pool
DB_CONNECTION_POOL_SIZE=20                       # Max connections (REQUIRED)
DB_CONNECTION_TIMEOUT=5000                       # Timeout in ms

# ==========================================
# REDIS CONFIGURATION (Cache & Queue)
# ==========================================
# Upstash Redis (Production - Recommended)
REDIS_HOST=default.your-id.upstash.io           # Redis hostname (REQUIRED)
REDIS_PORT=6379                                  # Redis port (REQUIRED)
REDIS_PASSWORD=your_redis_password               # Redis password (REQUIRED for Upstash)
REDIS_USERNAME=default                           # Upstash username

# OR Local Redis (Development)
# REDIS_HOST=localhost
# REDIS_PORT=6379

REDIS_MAX_RETRIES=3                              # Retry attempts
REDIS_RETRY_DELAY=300                            # Delay in ms

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_recommended  # (REQUIRED - min 32 chars)
JWT_EXPIRE=7d                                    # Token expiration (REQUIRED)
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_recommended # (REQUIRED)
JWT_REFRESH_EXPIRE=30d                           # Refresh token expiration

# ==========================================
# SECURITY & CORS
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,https://www.ecokids.in,https://app.ecokids.in  # (REQUIRED)
CORS_CREDENTIALS=true                            # Enable credentials
RATE_LIMIT_WINDOW=15                             # Minutes
RATE_LIMIT_MAX_REQUESTS=100                      # Requests per window
CSRF_SECRET=your_csrf_secret_key                 # CSRF protection

# ==========================================
# LOGGING & MONITORING
# ==========================================
LOG_LEVEL=info                                   # debug, info, warn, error (REQUIRED)
ENABLE_PINO_HTTP=true                            # HTTP request logging
METRICS_ENABLED=true                             # Prometheus metrics
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id  # Error tracking (RECOMMENDED for production)
OPENTELEMETRY_ENABLED=false                      # APM tracing (optional)

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# SendGrid for transactional emails (RECOMMENDED for production)
SENDGRID_API_KEY=SG.your_sendgrid_api_key       # SendGrid API key
SENDGRID_FROM_EMAIL=noreply@ecokids.in          # Sender email
SENDGRID_FROM_NAME=EcoKids India                # Sender name

# OR AWS SES (Alternative)
# AWS_SES_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_SES_FROM_EMAIL=noreply@ecokids.in

# ==========================================
# FILE STORAGE
# ==========================================
# AWS S3 for file uploads (RECOMMENDED for production)
AWS_S3_BUCKET=ecokids-uploads                   # S3 bucket name
AWS_S3_REGION=ap-south-1                        # S3 region (REQUIRED for S3)
AWS_ACCESS_KEY_ID=your_aws_access_key           # AWS access key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key       # AWS secret key
S3_PUBLIC_URL=https://ecokids-uploads.s3.ap-south-1.amazonaws.com  # CDN URL

# OR Local file storage (Development only)
UPLOAD_DIR=./uploads                            # Local upload directory
MAX_FILE_SIZE=50000000                          # 50MB in bytes

# ==========================================
# AI & MACHINE LEARNING
# ==========================================
# Google Cloud Vision API (For photo verification)
GOOGLE_CLOUD_PROJECT_ID=your_project_id         # GCP project ID
GOOGLE_CLOUD_KEY_FILE=./secrets/gcp-key.json   # Path to service account key

# OR AWS Rekognition (Alternative)
# AWS_REKOGNITION_ENABLED=true
# AWS_REKOGNITION_CONFIDENCE=80

# OpenAI / GPT for quiz generation (OPTIONAL)
OPENAI_API_KEY=sk-your_openai_api_key          # OpenAI API key
OPENAI_MODEL=gpt-4                              # Model version
OPENAI_MAX_TOKENS=2000                          # Max tokens per request

# ==========================================
# SMS & NOTIFICATIONS
# ==========================================
# Twilio for SMS (School onboarding, OTP)
TWILIO_ACCOUNT_SID=your_twilio_sid              # Twilio account SID
TWILIO_AUTH_TOKEN=your_twilio_auth_token        # Twilio auth token
TWILIO_PHONE_NUMBER=+1234567890                 # Verified Twilio number

# OR AWS SNS (Alternative)
# AWS_SNS_ENABLED=true

# Firebase Cloud Messaging (Push notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id    # Firebase project ID
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n... # Service account key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com

# ==========================================
# EXTERNAL INTEGRATIONS
# ==========================================
# Government Reporting (NEP 2020, DPDP compliance)
GOVT_API_ENDPOINT=https://govapi.education.gov.in/v1  # Government API URL
GOVT_API_KEY=your_government_api_key            # Government API key
GOVT_SCHOOL_CODE=YOUR_SCHOOL_CODE               # Your school's government code
UDISE_API_URL=https://api.udiseplus.gov.in/v1   # UDISE verification API
UDISE_API_KEY=your_udise_api_key                # UDISE API key
CERT_IN_CONTACT_EMAIL=security@ecokids.in       # CERT-In reporting contact

# NGO Partnerships (For eco-clubs)
NGO_API_ENDPOINT=https://api.ngo-partner.org    # NGO API endpoint
NGO_API_KEY=your_ngo_api_key                    # NGO API key

# ==========================================
# WORKER & QUEUE CONFIGURATION
# ==========================================
BULLMQ_CONCURRENCY=5                            # BullMQ job concurrency
BULLMQ_RATE_LIMIT=50                            # Jobs per second
BULLMQ_RETRY_DELAY=300                          # Retry delay in ms
BULLMQ_MAX_RETRIES=3                            # Max retry attempts

# Job Processing Times
JOB_TIMEOUT_BADGES=10000                        # Badge award job timeout (ms)
JOB_TIMEOUT_SCHOOL_AGGREGATION=30000            # School aggregation timeout (ms)
JOB_TIMEOUT_PHOTO_AI=20000                      # AI photo verification timeout (ms)
JOB_TIMEOUT_PARENT_REPORT=15000                 # Parent report generation timeout (ms)

# ==========================================
# FEATURE FLAGS (Rollout Percentages: 0-100)
# ==========================================
# AI Features
FEATURE_AI_PHOTO_VERIFICATION=true              # Enable AI photo verification
ROLLOUT_AI_PHOTO=50                             # Percentage of users (50% rollout)
FEATURE_AI_RECOMMENDATIONS=true                 # Enable personalized recommendations
ROLLOUT_RECOMMENDATIONS=30                      # Percentage (30% rollout)
FEATURE_SMART_PATHS=true                        # Enable smart learning paths
ROLLOUT_SMART_PATHS=40                          # Percentage (40% rollout)

# Social Features
FEATURE_BUDDY_SYSTEM=true                       # Enable buddy system
ROLLOUT_BUDDY=100                               # Full rollout
FEATURE_TEAM_CHALLENGES=true                    # Enable team challenges
ROLLOUT_TEAM_CHALLENGES=60                      # Percentage (60% rollout)
FEATURE_COMMENTS=true                           # Enable feed comments
ROLLOUT_COMMENTS=70                             # Percentage (70% rollout)

# Gamification
FEATURE_ADVANCED_BADGES=true                    # Enable advanced badges
ROLLOUT_BADGES=80                               # Percentage (80% rollout)
FEATURE_LEADERBOARDS=true                       # Enable leaderboards
ROLLOUT_LEADERBOARDS=100                        # Full rollout
FEATURE_WEEKLY_MISSIONS=true                    # Enable weekly missions
ROLLOUT_MISSIONS=75                             # Percentage (75% rollout)

# Teacher Features
FEATURE_APPROVAL_WORKFLOW=true                  # Enable approval workflow
ROLLOUT_APPROVAL=100                            # Full rollout
FEATURE_TEACHER_ANALYTICS=true                  # Enable teacher analytics
ROLLOUT_TEACHER_ANALYTICS=85                    # Percentage (85% rollout)
FEATURE_ECO_CLUBS=true                          # Enable eco-clubs
ROLLOUT_ECO_CLUBS=90                            # Percentage (90% rollout)

# Parent & School
FEATURE_PARENT_REPORTS=true                     # Enable parent reports
ROLLOUT_PARENT_REPORTS=100                      # Full rollout
FEATURE_SCHOOL_ANALYTICS=true                   # Enable school analytics
ROLLOUT_SCHOOL_ANALYTICS=95                     # Percentage (95% rollout)
FEATURE_GOVERNMENT_INTEGRATION=true             # Enable government integration
ROLLOUT_GOVERNMENT=100                          # Full rollout

# Compliance
FEATURE_DPDP_COMPLIANCE=true                    # Enable DPDP compliance features
ROLLOUT_DPDP=100                                # Full rollout

# ==========================================
# COMPLIANCE & DATA PRIVACY
# ==========================================
# DPDP Act 2023 (Indian Data Privacy)
DPDP_ENABLED=true                               # Enable DPDP compliance
PARENTAL_CONSENT_REQUIRED=true                  # Require parental consent for <18
DATA_RETENTION_DAYS=1825                        # 5-year data retention policy
USER_DATA_EXPORT_ENABLED=true                   # Allow users to export personal data
USER_DATA_DELETION_ENABLED=true                 # Allow users to request data deletion
BACKUP_ENCRYPTION_KEY=replace_with_32_char_secret # Required for deletion backup encryption
DATA_RESIDENCY_REGION=ap-south-1                # India-only region requirement
STORAGE_REGION=ap-south-1                       # Object storage region
ENFORCE_INDIA_DATA_RESIDENCY=true               # Block service if region is outside India

# POCSO Act Compliance
POCSO_ENABLED=true                              # Enable child safety features
CONTENT_MODERATION_ENABLED=true                 # Auto-moderate user-generated content
ABUSE_REPORTING_EMAIL=safety@ecokids.in         # Report abuse email

# ==========================================
# DEPLOYMENT & DEVOPS
# ==========================================
# Docker & Kubernetes
DOCKER_REGISTRY=your-registry.azurecr.io        # Docker registry URL
DOCKER_IMAGE_TAG=latest                         # Image tag
KUBERNETES_NAMESPACE=ecokids-prod               # K8s namespace

# CI/CD
GITHUB_TOKEN=ghp_your_github_token              # GitHub API token for actions
DEPLOY_WEBHOOK_SECRET=your_webhook_secret       # Deployment webhook secret

# ==========================================
# BACKUP & DISASTER RECOVERY
# ==========================================
BACKUP_ENABLED=true                             # Enable automated backups
BACKUP_INTERVAL=daily                           # Backup frequency: hourly, daily, weekly
BACKUP_RETENTION_DAYS=90                        # Keep backups for 90 days
BACKUP_STORAGE=s3                               # Storage: s3, gcs, azure
BACKUP_S3_BUCKET=ecokids-backups                # S3 bucket for backups
BACKUP_ENCRYPTION=true                          # Encrypt backups

# ==========================================
# MONITORING & ALERTING
# ==========================================
# Better Uptime (Uptime Monitoring & Alerting)
BETTER_UPTIME_API_KEY=your_better_uptime_key    # Better Uptime API key
BETTER_UPTIME_CHECK_INTERVAL=60                 # Check frequency in seconds
HEALTH_CHECK_ENDPOINT=/health                   # Health check endpoint

# ==========================================
# DEVELOPMENT & DEBUG
# ==========================================
DEBUG=false                                      # Enable debug mode
MOCK_AI_RESPONSES=false                          # Mock AI responses for testing
SKIP_EMAIL_VERIFICATION=false                   # Skip email verification (dev only)
ALLOW_UNSIGNED_TOKENS=false                     # Allow unsigned JWT tokens (dev only)

# ==========================================
# DEMO & TESTING
# ==========================================
DEMO_MODE=false                                  # Enable demo mode with seeded data
DEMO_SCHOOL_ID=demo_school_123                  # Demo school ID
DEMO_TEACHER_ID=demo_teacher_123                # Demo teacher ID
DEMO_STUDENT_IDS=demo_student_1,demo_student_2,demo_student_3  # Demo user IDs
LOAD_SEED_DATA=false                            # Auto-load seed data on startup

# ==========================================
# CONFERENCE DEMO (For Live Presentations)
# ==========================================
CONFERENCE_MODE=false                           # Enable conference-specific configurations
CONFERENCE_DEMO_SCHOOLS=3                       # Number of demo schools
CONFERENCE_DEMO_STUDENTS_PER_SCHOOL=10          # Students per school
CONFERENCE_DEMO_ACTIVITIES=500                  # Pre-recorded activities
DEMO_CREDENTIALS_STUDENT=student1@demo.ecokids.in:Demo@123  # Demo credentials
DEMO_CREDENTIALS_TEACHER=teacher1@demo.ecokids.in:Demo@123
DEMO_CREDENTIALS_ADMIN=admin1@demo.ecokids.in:Demo@123

# ==========================================
# NOTES
# ==========================================
# REQUIRED variables must be set before deployment
# RECOMMENDED variables should be set for production
# OPTIONAL variables can be omitted (defaults will be used)
#
# For production deployment:
# 1. Use strong, unique values for all secrets (JWT_SECRET, REDIS_PASSWORD, etc.)
# 2. Store secrets in a vault (AWS Secrets Manager, HashiCorp Vault, etc.)
# 3. Never commit .env to git - use .env.example instead
# 4. Enable SSL/TLS for all connections
# 5. Set up monitoring, alerting, and backups
# 6. Configure rate limiting and DDoS protection
# 7. Enable SENTRY for error tracking
# 8. Set up automated daily backups
